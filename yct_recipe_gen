# yct_recipe_gen
# A very simple Yocto recipe generator script.
# Usage: yct_recipe_gen [-d] meta-<layername> recipe-name
# (c) Kaiwan N Billimoria, kaiwanTECH
#
#----------------------------------------------------------------------
# Example: if you run this script to create a meta layer named 'meta-myinit'
# and, within it, a 'recipe' / package called 'installfiles' with, typically:
#  ./yct_recipe_gen meta-myinit installfiles
# this is the dir structure it generates, along with the layer.conf, files
# and the installfiles_0.1.bb recipe template files generated!
#
# meta-myinit/
# └── recipes-myinit
#     └── installfiles
#         ├── files
#         │   ├── 0setup.bash
#         │   └── debug_script
#         └── installfiles_0.1.bb
# 
#----------------------------------------------------------------------
name=$(basename "$0")
PFX=$(dirname "$(which "$0")")    # dir in which the common code and tools reside
source "${PFX}"/common || {
  echo "${name}: could not source 'common', aborting..." ; exit 1
}
WARN=0

#-- Populate the meta-<lyr>/recipes-<rcp>/files directory with reqd files
add_to_files_dir()
{
echo
echo "[+] Add required files to the meta-<lyr>/recipes-<rcp>/files directory"

local wd=800 ht=450
local RCP_FILES RCPF_ARR re

while true ; do
  RCP_FILES=$(yad --file-selection --multiple  \
       --center --width=${wd} --height=${ht} \
       --title="${name}: Select required files for 'files' dir (for ${LAYER}:${RCP_NAME})" 2>/dev/null || true)
 dprint "RCP_FILES = ${RCP_FILES}"

 if [[ ! -z "${RCP_FILES}" ]] ; then
    #echo "Required files : ${RCP_FILES}"
    IFS='|'  # delimiter that yad inserts
    read -ra RCPF_ARR <<< "${RCP_FILES}"
       # ref: https://stackoverflow.com/questions/918886/how-do-i-split-a-string-on-a-delimiter-in-bash
    for RFIL in "${RCPF_ARR[@]}"
    do
      printf "  %40s -> %30s\n" "${RFIL}" "${RCP_FILES_DIR}"
      cp --preserve=all "${RFIL}" "${RCP_FILES_DIR}"/
    done
    unset IFS
  else
    echo "Cancelled..." ; return
  fi

  echo -n "Add more files to recipe's 'files' dir? [y/N] "
  read -r re
  #echo "re = ${re}"
  if [ "${re}" != "y" ] && [ "${re}" != "Y" ] ; then
    break
  fi
done

ls -l "${RCP_FILES_DIR}"/
echo
} # end add_to_files_dir()

#-- Generate the meta-<lyr>/recipes-<rcp>/<rcp>.bb recipe file
gen_recipe_file()
{
echo
echo "[+] Generate the layer's recipe file"

local PV=0 PR=1
#RECIPE_FILE=${BUILDDIR}/${LAYER}/recipes-${layer_token2}/${RCP_NAME}/${RCP_NAME}_${PV}.${PR}.bb
RECIPE_FILE=${LAYER}/recipes-${layer_token2}/${RCP_NAME}/${RCP_NAME}_${PV}.${PR}.bb

# TODO : TEMP
#rm -f ${RECIPE_FILE}

[[ -f "${RECIPE_FILE}" ]] && {
  QP
  warn "Skipping as recipe file already exists:
"
  ls -l "${RECIPE_FILE}"
  WARN=1
  return
}

#-- Get the 'files' dir content
local fname

local tmpf=$(mktemp)
ls "${RCP_FILES_DIR}" > "${tmpf}"

# SRCURI : files copied -without the 'file://' prefix;
# required for the FILES:${PN} += ... directive below
local SRCURI_FILES="" SRCURI=""
for fname in $(cat "${tmpf}")
do
  #echo "fname : ${fname}"
  SRCURI_FILES="${SRCURI_FILES} file://${fname}"
  SRCURI="${SRCURI} ${fname}"
done
SRCURI_FILES="${SRCURI_FILES} \\"
SRCURI="${SRCURI} \\"
rm -f "${tmpf}"
#echo "
#++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
#SRCURI_FILES : ${SRCURI_FILES}
#++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++"

local D=""
cat << @EOF@ > "${RECIPE_FILE}"
# This recipe template's generated by the ${name} script, part of the simple
# 'yocto-tools' repo:
#  https://github.com/kaiwan/yocto_tools
# (c) kaiwanTECH
# $(date)
# (Note- this script generates syntax appropriate for honister 3.4 onwards, the
# syntax is of the form x:y not x_y !
# For lower versions, you'll have to manually change the syntax.)
DESCRIPTION = ""

# Section: 'examples'; replace with appropriate section; f.e.: utils, graphics, apps, ...
SECTION = "examples"

HOMEPAGE = ""

# NOTE: 
# We could set - and comment out - LICENSE to "CLOSED" to allow you to at least start
# building - if this is not accurate with respect to the licensing of the
# software being built (it will not be in most cases) you must specify the
# correct value before using this recipe for anything other than initial
# testing/development!
#LICENSE = "CLOSED"
#LIC_FILES_CHKSUM = ""
# LICENSE set to 'MIT'; change if you wish...
LICENSE = "MIT"
LIC_FILES_CHKSUM = "\\
	file://\${COREBASE}/meta/files/common-licenses/MIT;md5=0835ade698e0bcf8506ecda2f7b4f302 \\
	"

# Fill Runtime DEPENDencieS - the RDEPENDS value - for this recipe's package;
# (Note- honister 3.4 onwards, the syntax is of the form x:y not x_y !
# f.e. = "bash dpkg python"
RDEPENDS:\${PN} = ""

# Location of files
#  Tip: append ';unpack=0 \' to not unpack the file
SRC_URI = "${SRCURI_FILES}
   "

# The FILE_\${PN} addition below is required to avoid the 'installed but not shipped in any package'
# error; it's left commented out by default
# (Note- honister 3.4 onwards, the syntax is of the form x:y not x_y !
#FILES:\${PN} += "\${base_prefix}/${SRCURI}"

IMAGE_FEATURES += ""

# NOTE !!!
# Yocto >=5.3: change the variable from WORKDIR to UNPACKDIR
S = "\${UNPACKDIR}"
# FYI, \${S} = \${UNPACKDIR} = \${TMPDIR}/work/\${PACKAGE_ARCH}-\${DISTRO}-\${TARGET_OS}/\${PN}/\${PV}-\${PR}
#  \${D} = \${UNPACKDIR}/image
# f.e, here:
#  poky/rpi-build/tmp/work/aarch64-poky-linux/myprj/1.0-r0/image/
#                 [              UNPACKDIR                ][image]
#      [build-dir][             tmp workdir               ]
# [rootfs] is a 'partial' rootfs - one made for ONLY this recipe's rootfs
# content! The final rootfs is a union of all the recipe/pkg [rootfs]'s

do_configure () {
	# Specify any needed configure commands here
	:
}

do_compile () {
	# Specify compilation commands here
	:
}

do_install () {
	# Specify install commands here; examples below:
	# (1) create a dir /etc/init.d with:
	#  install -d -m 0755 \${D}/\${sysconfdir}/init.d
	# (2) Tip: to generate a soft link, first cd to the dir and then create it;
	#  cd ${D}/etc/rc5.d
	#  ln -s ../init.d/myprg_install.sh S99myprg
	:
}
@EOF@
ls -l "${RECIPE_FILE}"
} # end gen_recipe_file()


### 'main'
which yad >/dev/null || {
  echo "${name}: 'yad' (yet another dialog) util missing, pl install the 'yad' package and retry...
(yes, as of now at least, this script requires to be run in a GUI-only environment
 sudo apt install yad )"
  exit 1
}

setup_env -q  # from the 'common' script

set +u
[ -z "${BUILDDIR}" ] && {
  echo "${name}: we expect you to be running this script from within your Yocto workspace.
So, you need to do that - source the Yocto environment first; typically:
cd <yocto-workspace>/
source oe-init-build-env [build-dir]

Perhaps you have a fully setup Yocto workspace but are running this script from another directory;
in this case, simply switch to your Yocto workspace and run it from there, f.e., like this:
~/yocto_tools/${name} [...params...]"
  exit 1
}
set -u

echo "
+++ NOTE Carefully Please +++
Your current Yocto 'build' dir (\$BUILDDIR or \$TOPDIR) is
\"${BUILDDIR}\"

This implies that the layer/recipe dir tree and files will be created like this:"
if [[ ${OLDER_VER} -eq 1 ]] ; then
   echo "(This is an older Yocto < 5.3): so, within this Yocto 'build' dir displayed above"
else
   echo "(This is a newer Yocto >= 5.3): so, within this project's layer location, here determined to be:
 ${PRJ_LAYERS}"
fi

echo "
If this is fine, press [Enter] to continue, else press ^C to abort"
read -r

# usage check
[ $# -lt 2 ] && {
  echo "Usage: ${name} [-d] meta-<layername> recipe-name"
  echo "Eg. ${name} meta-mylayer helloworld
 -d : run in 'debug' mode"
  exit 1
}
# arg processing
DEBUG=0
if [ $# -eq 3 ] && [ "$1" = "-d" ] ; then
  DEBUG=1
  LAYER=$2
  RCP_NAME=$3
else
  LAYER=$1
  RCP_NAME=$2
fi
# strip out any '/' chars
LAYER=$(echo "${LAYER}" | sed 's/\///g')
RCP_NAME=$(echo "${RCP_NAME}" | sed 's/\///g')
dprint "LAYER = ${LAYER}, RCP_NAME = ${RCP_NAME}"

LAYER_DIR_PFX=${BUILDDIR}
# New layer location: for 'new' Yocto >= 5.3: the project layers dir location
# should be used, not just under the build-dir
[[ ${OLDER_VER} -eq 0 ]] && {
   set +u
   [[ ! -z "${PRJ_LAYERS}" ]] && LAYER_DIR_PFX=${PRJ_LAYERS}
   set -u
}

export LAYER=${LAYER_DIR_PFX}/${LAYER}
dprint "LAYER = ${LAYER}"
# Append a $PR = 0.1 to the recipe-name

# TODO : don't abort, proceed using existing layer for new recipe..
LAYER_EXISTS=0
[[ -d ${LAYER} ]] && LAYER_EXISTS=1 #&& die "Layer ${LAYER} already exists"

#-- Validity checks
LAYERNAME="$(basename ${LAYER})"
[[ "${LAYERNAME})" != *"-"* ]] && die "Your meta-layername is \"${LAYERNAME}\" ; convention dictates it should be of the form \"meta-<foo>\""
layer_metatoken=$(echo "${LAYERNAME})" |cut -d"-" -f1)
[ "${layer_metatoken}" != "meta" ] && die " Your meta-layername is \"${LAYERNAME}\"; convention dictates it should be of the form \"meta-<foo>\""
export layer_token2=$(echo "${LAYERNAME}" |cut -d"-" -f2)
#dprint "layer_token2 = ${layer_token2}"
[ -z "${layer_token2}" ] && die " Your meta-layername is \"${LAYERNAME}\"; convention dictates it should be of the form
 \"meta-<foo>\" (the <foo> part is missing!)"

TOP=$(pwd)
cd "${BUILDDIR}" || exit 1

[[ ${LAYER_EXISTS} -eq 0 ]] && {
  bitbake-layers create-layer ${LAYER}
  # rm the unnecessary 'recipes-example' dir
  rm -rf ${LAYER}/recipes-example
}

# Setup the specified recipe dir and files
#RCP_FILES_DIR=${BUILDDIR}/${LAYER}/recipes-${layer_token2}/${RCP_NAME}
RCP_FILES_DIR=${LAYER}/recipes-${layer_token2}/${RCP_NAME}
dprint "RCP_FILES_DIR = ${RCP_FILES_DIR}"
[[ -d ${RCP_FILES_DIR} ]] && die "Layer:Recipe :: ${LAYER}:recipe-${layer_token2}/${RCP_NAME} already exists
Either use another recipe name or create a new layer:recipe"

#-- Create the basic tree
RCP_FILES_DIR=${RCP_FILES_DIR}/files
mkdir -p "${RCP_FILES_DIR}" || die "Creating recipe dir \"${RCP_FILES_DIR}\" failed, aborting..."

# the 'bitbake-layers create-layer <...>' cmd itself sets up the conf/layer.conf file
add_to_files_dir
gen_recipe_file
# Only add the layer if not there already
bitbake-layers show-layers |grep "${LAYERNAME}" >/dev/null || bitbake-layers add-layer ${LAYER}

echo
[ ${WARN} -ne 0 ] && warn "
*** ${name}: Note: some WARNings were generated ***
"
echo "Layer \"$(basename ${LAYER})\" recipe \"${RCP_NAME}\" setup:
"
#tree "${BUILDDIR}"/"${LAYER}"/recipes-"${layer_token2}"
#tree "${BUILDDIR}"/"${LAYER}"/
tree "${LAYER}"/

cd "${TOP}"

red_highlight "
${name}: Don't forget to:"
echo " a) Verify and update the recipe file as required : ${RECIPE_FILE}
 b) Update your conf/local.conf (or other) file to include the recipe in the build:
             IMAGE_INSTALL:append = \" ${RCP_NAME}\"
    TIP: by doing:
             bitbake-layers show-recipes ${RCP_NAME}
         you can check if your recipe is actually 'seen' by bitbake
 c) Test just this recipe        : bitbake ${RCP_NAME}
 d) Rebuild the project and test : bitbake <image-name>
 "
exit 0
